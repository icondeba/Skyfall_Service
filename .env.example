APP_NAME=Skyfall Lounge API
ENVIRONMENT=development

# Local SQL Server example:
# DATABASE_URL=mssql+pyodbc://localhost/SkyfallLounge?driver=ODBC+Driver+18+for+SQL+Server&trusted_connection=yes&TrustServerCertificate=yes

# Supabase PostgreSQL example:
# DATABASE_URL=postgresql+psycopg://postgres.your-project:your-password@aws-0-ap-south-1.pooler.supabase.com:6543/postgres
DATABASE_URL=mssql+pyodbc://localhost/SkyfallLounge?driver=ODBC+Driver+18+for+SQL+Server&trusted_connection=yes&TrustServerCertificate=yes

FRONTEND_LOCAL_ORIGIN=http://localhost:3000
FRONTEND_PRODUCTION_ORIGIN=https://skyfall-lounge.example.com
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://skyfall-lounge.example.com

AUTH_DISABLED=true
SECRET_KEY=dev-only-change-me
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_KEY=your-supabase-service-key
SUPABASE_REALTIME_CHANNEL=skyfall-lounge

RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret
RAZORPAY_WEBHOOK_SECRET=your-razorpay-webhook-secret

META_WA_TOKEN=your-meta-whatsapp-token
META_WA_PHONE_ID=your-meta-phone-id

TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+10000000000

REDIS_URL=
CAFE_NAME=Skyfall Lounge
CAFE_ADDRESS=Skyfall Lounge, Your Cafe Address
CAFE_GSTIN=
CAFE_PHONE=+910000000000
CAFE_SOCIAL_HANDLES=@skyfalllounge
CURRENCY=INR
TAX_RATE=0.05
